# Copy to .env for local/prod
PORT=7860
HOST=0.0.0.0

# Optional bootstrap key (overrides empty settings)
# AURORA_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...

# Public URL shown in docs (optional)
# AURORA_PUBLIC_URL=https://your-app.example.com


# ---- DevSecOps / security ----
AURORA_SECURITY_ENABLED=true
AURORA_RATE_LIMIT=true
AURORA_RL_CHAT_PER_MIN=30
AURORA_RL_API_PER_MIN=120
AURORA_RL_MCP_PER_MIN=40
AURORA_MAX_BODY_BYTES=2000000
AURORA_MAX_MESSAGE_CHARS=100000
AURORA_REQUIRE_APP_TOKEN=false
# AURORA_APP_TOKEN=change-me-to-a-long-random-string
# AURORA_CORS_ORIGINS=https://your-domain.com
AURORA_HSTS=true
AURORA_AUDIT_LOG=true
AURORA_BLOCK_PRIVATE_URLS=true
AURORA_TRUST_PROXY=true
